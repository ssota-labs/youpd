{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "cwd": "apps/web",
      "runtimeExecutable": "/tmp/youpd-run.sh",
      "runtimeArgs": ["pnpm", "run", "dev"],
      "port": 3000
    },
    {
      "name": "mobile-web",
      "cwd": "apps/mobile",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "expo", "start", "--web", "--port", "8081", "--clear"],
      "port": 8081
    }
  ]
}
