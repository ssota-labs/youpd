# apps/web environment template — copy to apps/web/.env.local for local dev.
# Next.js 16 only auto-loads .env* from this directory; the root file is not
# consulted by `next dev` / `next build`.

# Local Supabase (matches `supabase start` output on default ports)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key

# Origin where magic-link emails should send users back. Used to build the
# `emailRedirectTo` URL on signInWithOtp. Defaults to http://localhost:3000.
SITE_URL=http://localhost:3000

# YouTube + quota (server-side for cron routes — same MCP policy)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Legacy single-key fallback. v0.7+: pool lives in Supabase
# `youtube_api_keys`; this env is only used to seed the first row on a fresh
# install (one-shot, via `pnpm --filter @youpd/api youtube-key:add` or the
# auto-seed in youtube-key-pool.ts).
YOUTUBE_API_KEY=
# Global daily YouTube quota budget. `YOUPD_DAILY_QUOTA_BUDGET_UNITS` is the
# v0.7 name; `QUOTA_DAILY_LIMIT` remains a legacy alias.
QUOTA_DAILY_LIMIT=9000
# Inter-page sleep (ms) between paginated YouTube calls inside a single
# request. Default 150; set "0" to disable. Keeps long pagination loops
# (e.g. 300 results per keyword) under YouTube's per-second cap.
YOUPD_INTER_PAGE_DELAY_MS=150

# Vercel Cron auth for `/api/cron/youpd/*` (production only)
CRON_SECRET=
