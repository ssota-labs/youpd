# apps/web environment template — copy to apps/web/.env.local for local dev.
# Next.js 16 only auto-loads .env* from this directory; the root file is not
# consulted by `next dev` / `next build`.

# Local Supabase (matches `supabase start` output on default ports)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key

# Origin where magic-link emails should send users back. Used to build the
# `emailRedirectTo` URL on signInWithOtp. Defaults to http://localhost:3000.
SITE_URL=http://localhost:3000
