# apps/mcp environment template — copy to apps/mcp/.env.local for local dev.
# Keep in sync with the root .env.example. Next.js 16 only auto-loads .env*
# from this directory; the root file is not consulted by `next dev` / `next build`.

# Local Supabase (matches `supabase start` output on default ports)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-status-service-role-key

# Dev port
MCP_PORT=3002

# MCP OAuth 2.1
# Issuer is the canonical origin of the MCP server's authorization endpoints.
# Resource is the exact MCP endpoint URI used for RFC 8707 audience binding —
# tokens are issued for and validated against this string.
MCP_OAUTH_ISSUER=http://localhost:3002
MCP_OAUTH_RESOURCE=http://localhost:3002/api/mcp

# YouTube Data API v3 — server-side only. Never expose under NEXT_PUBLIC_*.
YOUTUBE_API_KEY=

# Daily quota gate for YouTube units. Default 9000 leaves a 1000u safety margin
# against the upstream 10,000u/day Google Cloud limit.
QUOTA_DAILY_LIMIT=9000

# v0.12 REST-backed MCP wrappers. For local dev, run @youpd/web on :3000.
YOUPD_API_BASE_URL=http://localhost:3000
YOUPD_API_TOKEN=

# Public Notion template page (Duplicate target) returned by get_bundle_manifest.
# Empty during M1 — filled in M4 once the marketplace template is published.
BUNDLE_TEMPLATE_URL=
