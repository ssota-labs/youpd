# Copy to `.env` (ntn default) or `.env.local` and pass:
#   ntn workers exec healthcheck -d '{}' --local --dotenv .env.local
# Never commit real values — `.env*` is gitignored except `.env.example`.

# Notion: integration token used by `ntn workers exec --local` (context.notion).
# Create at https://www.notion.so/my-integrations
NOTION_API_TOKEN=

# YouPD REST (same Bearer as `YOUPD_API_TOKEN` on apps/web — see repo root `.env.example`)
YOUPD_API_BASE_URL=http://localhost:3000
YOUPD_API_TOKEN=

# Template DB data source IDs (not database page IDs): `ntn datasources resolve` etc.
# Keywords DB: collection URL from the workspace “데이터” hub or each database’s “Copy link to data source”.
YOUPD_KEYWORDS_DATA_SOURCE_ID=
YOUPD_HOT_VIDEO_DAILY_DATA_SOURCE_ID=
YOUPD_VIDEOS_DATA_SOURCE_ID=
YOUPD_CHANNELS_DATA_SOURCE_ID=
YOUPD_SNAPSHOTS_DATA_SOURCE_ID=
YOUPD_CHANNEL_SNAPSHOTS_DATA_SOURCE_ID=
YOUPD_COMMENTS_DATA_SOURCE_ID=
