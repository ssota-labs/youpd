# Non-secret env vars pushed to the production Notion worker on every CI deploy
# (see .github/workflows/deploy-notion-worker.yml).
#
# DO NOT put secrets in this file. Tokens live in GitHub Actions secrets and
# are appended by the workflow before `ntn workers env push`.
#
# Required GitHub Actions secrets:
#   NOTION_API_TOKEN   — Notion API token used by worker's context.notion
#   YOUPD_API_TOKEN    — Bearer for YouPD REST (apps/web /api/youpd/rest/*)

# Notion + YouPD REST endpoints
NOTION_API_BASE_URL=https://api.notion.com
YOUPD_API_BASE_URL=https://youpd-web.vercel.app/

# Notion data source IDs (8 tables — must match CANONICAL in src/lib/schema.ts)
YOUPD_KEYWORDS_DATA_SOURCE_ID=e38346da-c456-8276-a909-87cacf65f04d
YOUPD_VIDEOS_DATA_SOURCE_ID=b04346da-c456-83d0-8f29-87a839e0c8ec
YOUPD_CHANNELS_DATA_SOURCE_ID=f90346da-c456-832f-8361-87c3f2d349b0
YOUPD_SNAPSHOTS_DATA_SOURCE_ID=19c346da-c456-8397-b3df-874ffd82eacf
YOUPD_CHANNEL_SNAPSHOTS_DATA_SOURCE_ID=fe0346da-c456-83b9-9411-071e39965cd0
YOUPD_COMMENTS_DATA_SOURCE_ID=6c1346da-c456-82e6-8808-8785cbb0d138
YOUPD_HOT_VIDEO_DAILY_DATA_SOURCE_ID=5a0346da-c456-82cc-a4d0-874bd08e7ef7
YOUPD_KEYWORD_IDEAS_DATA_SOURCE_ID=0119f8e5-af91-4adc-a15a-b8713c8cc4b2

# v0.7 trackKeywordIdeasDue tunables (all optional — defaults come from the
# tool itself). Override here when you want the prod default to differ.
YOUPD_KEYWORD_IDEA_LIMIT=20
YOUPD_RESULTS_PER_KEYWORD=300
YOUPD_KEYWORD_TRACKING_ENABLED=true
# NOTE: `YOUPD_INTER_PAGE_DELAY_MS` controls inter-page sleep in paginated
# YouTube searches and is read by **apps/web** (REST handler), not the worker.
# Set it on Vercel for the @youpd/web project, not here. Default 150ms.
