# apps/admin environment template — copy to apps/admin/.env.local for local dev.
# Next.js 16 only auto-loads .env* from this directory.

DATABASE_URL=replace-with-supabase-status-database-url
SUPABASE_URL=replace-with-supabase-status-api-url
SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-status-service-role-key
NEXT_PUBLIC_SUPABASE_URL=replace-with-supabase-status-api-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key
