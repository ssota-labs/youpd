{
  "name": "youpd",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "bash scripts/test-integration.sh",
    "test:e2e": "playwright test",
    "test:e2e:artifacts": "playwright test --reporter=html,list",
    "db:up": "supabase start",
    "db:down": "supabase stop",
    "db:reset": "supabase db reset --local",
    "db:generate": "pnpm --filter @youpd/db exec drizzle-kit generate",
    "db:push": "node -e \"console.error('drizzle-kit migrate is forbidden by AGENTS.md. Use supabase migration new + pnpm db:reset.'); process.exit(1)\"",
    "youtube:keys:sync": "pnpm --filter @youpd/api youtube:keys:sync",
    "worktree:env": "bash scripts/link-env-from-main.sh",
    "env:sync": "bash scripts/sync-env.sh",
    "format": "prettier --write .",
    "storybook": "pnpm --filter @youpd/ui storybook",
    "build-storybook": "pnpm --filter @youpd/ui build-storybook"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
