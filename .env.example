# Local Supabase defaults (matches `supabase start` output on default ports)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-status-service-role-key

# Public (browser-safe) — these may differ from SUPABASE_URL when deployed
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key

# Dev ports
WEB_PORT=3000
ADMIN_PORT=3001
MCP_PORT=3002

# MCP OAuth 2.1 (apps/mcp)
# Issuer is the canonical origin of the MCP server's authorization endpoints.
# Resource is the exact MCP endpoint URI used for RFC 8707 audience binding —
# tokens are issued for and validated against this string.
MCP_OAUTH_ISSUER=http://localhost:3002
MCP_OAUTH_RESOURCE=http://localhost:3002/api/mcp

# YouTube Data API v3 (apps/mcp tools)
# Server-side only — never expose under NEXT_PUBLIC_*.
YOUTUBE_API_KEY=

# Daily quota gate for YouTube units. Default 9000 leaves a 1000u safety
# margin against the upstream 10,000u/day Google Cloud limit.
QUOTA_DAILY_LIMIT=9000

# Public Notion template page (Duplicate target) returned by get_bundle_manifest.
# Empty during M1 — filled in M4 once the marketplace template is published.
BUNDLE_TEMPLATE_URL=

# v0.4 Thumbnail Designer
# Origin used to build /designer iframe URLs returned by MCP tools.
YOUPD_APP_URL=http://localhost:3000
# Supabase Storage bucket that holds rendered PNG exports.
THUMBNAIL_EXPORT_BUCKET=thumbnail-exports
# Base URL for hosted Korean font files (Pretendard-Regular.otf,
# Pretendard-Bold.otf). Leave empty in dev to fall back to system fonts.
FONT_CDN_BASE_URL=
