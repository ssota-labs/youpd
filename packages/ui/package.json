      "components/ui/*": [
        "src/components/ui/*"
      ],
      "components/ssota-ui/*": [
        "src/components/ssota-ui/*"
      ],
      "hooks/*": [
        "src/hooks/*"
      ],
      "lib/*": [
        "src/lib/*"
      ],
      "globals.css": [
