{
  "name": "@youpd/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./mcp/tools": "./src/mcp/tools/index.ts",
    "./mcp/version": "./src/mcp/version/index.ts",
    "./mcp/quota": "./src/mcp/quota.ts",
    "./collection": "./src/collection/index.ts",
    "./rest": "./src/rest/index.ts",
    "./rest/harvests": "./src/rest/harvests/index.ts",
    "./thumbnail": "./src/thumbnail/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(api) no lint configured\"",
    "test": "vitest run",
    "seed:templates": "tsx --import ./scripts/register-shim.mjs scripts/seed-templates.ts",
    "e2e:thumbnail": "tsx --import ./scripts/register-shim.mjs scripts/e2e-thumbnail.ts",
    "youtube-key:add": "tsx --import ./scripts/register-shim.mjs scripts/youtube-key-add.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@youpd/composer-core": "workspace:*",
    "@youpd/composer-render-satori": "workspace:*",
    "@youpd/db": "workspace:*",
    "@youpd/supabase": "workspace:*",
    "@youpd/types": "workspace:*",
    "@youpd/youtube": "workspace:*",
    "satori": "^0.12.0",
    "server-only": "^0.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@youpd/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
