{
  "name": "@youpd/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./mcp/tools": "./src/mcp/tools/index.ts",
    "./mcp/version": "./src/mcp/version/index.ts",
    "./mcp/quota": "./src/mcp/quota.ts",
    "./collection": "./src/collection/index.ts",
    "./query": "./src/query/index.ts",
    "./rest": "./src/rest/index.ts",
    "./youtube": "./src/youtube/index.ts",
    "./home": "./src/home/index.ts",
    "./reference-folders": "./src/reference-folders/index.ts",
    "./thumbnail-templates": "./src/thumbnail-templates/index.ts",
    "./copy-templates": "./src/copy-templates/index.ts",
    "./intro-templates": "./src/intro-templates/index.ts",
    "./thread-templates": "./src/thread-templates/index.ts",
    "./social": "./src/social/index.ts",
    "./thumbnail-generation": "./src/thumbnail-generation/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(api) no lint configured\"",
    "test": "vitest run",
    "youtube:keys:sync": "tsx --import ./scripts/register-shim.mjs scripts/sync-youtube-keys.ts",
    "youtube-key:add": "tsx --import ./scripts/register-shim.mjs scripts/youtube-key-add.ts"
  },
  "dependencies": {
    "@youpd/db": "workspace:*",
    "@youpd/supabase": "workspace:*",
    "@youpd/types": "workspace:*",
    "@youpd/youtube": "workspace:*",
    "server-only": "^0.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@youpd/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
